{
  "manifest_version": 3,
  "name": "AutoRefresh",
  "version": "1.0",
  "description": "Automatically refreshes pages after a set interval.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "alarms",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
